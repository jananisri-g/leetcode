class Solution {
public:
    vector<int> intersect(vector<int>& nums1, vector<int>& nums2) {

        if(nums1.size() > nums2.size())
            return intersect(nums2, nums1);

        unordered_map<int,int> hash;

        for(int num : nums1)
            hash[num]++;

        vector<int> result;

        for(int num : nums2){
            auto it = hash.find(num);
            if(it != hash.end() && it->second > 0){
                result.push_back(num);
                it->second--;
            }
        }

        return result;
    }
};
