// TC: O(N)
// SC: O(N)

class Solution {
public:
    int pivotInteger(int n) {
        int rightSum = 0;
        for(int i = 1; i <= n; i++) rightSum += i;
        int leftSum = 0;
        for(int i = 1; i <= n; i++){
            rightSum -= i;
            leftSum += (i - 1);
            if(rightSum == leftSum) return i;
        }
        return -1;
    }
};

