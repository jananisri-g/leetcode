// TC: O(1)
// SC: O(1)

class Solution {
public:
    int pivotInteger(int n) {
        int total= n*(n+1)/2;
        int x=(int) sqrt(total);
        if(total==x*x)
        return x;
        else
        return -1;
    }
};
