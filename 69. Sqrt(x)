class Solution {
public:
    int mySqrt(int x) {
        if(x <= 1) return x;
        int low = 0, high = x / 2;
        int answer = -1;
        while(low <= high){
            long mid = (low + high) / 2;  //if not long, stack overflow occurs.
            if((mid * mid) <= x){
                answer = mid;
                low = mid + 1;
            }
            else high = mid - 1;
        }
        return answer;
    }
};

