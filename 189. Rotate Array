class Solution {
public:
    void rotate(vector<int>& nums, int k) {
        int n = nums.size();
        if(k > nums.size()) k = k % nums.size();
        vector<int> result;
        for(int i = n - k; i < n; i++) result.push_back(nums[i]);
        for(int i = 0; i <= n - k - 1; i++) result.push_back(nums[i]);
        nums = result;
        return;
    }
};



