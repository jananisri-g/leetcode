class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        if(nums.size() < 2) return 1;
        int n = nums.size();
        int i = 0, j = 1;
        while( j < n){
            if(nums[i] != nums[j]){
                i++;
                nums[i] = nums[j];
            }
            j++;
        }
        return i+1;
    }
};
