class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int,int> result;
        
        for(int i = 0; i < nums.size(); i++){
            int x = target - nums[i];
            
            if(result.find(x) != result.end()){
                return {result[x], i};
            }
            
            result[nums[i]] = i;
        }
        
        return {};
    }
};
