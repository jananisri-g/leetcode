/* finding the result by multiplying x n times will result in O(N) which is very high.
we use something called binary exponentiation.
if n is even,  x ^ n = ((x ^ 2)) ^ n / 2
if n is odd, x ^ n = x * (x ^ (n - 1))*/

class Solution {
public:
    double myPow(double x, int n) {
        long N = n;
        
        if(N < 0){
            x = 1 / x;
            N = -N;
        }

        double result = 1;

        while(N > 0){
            if(N % 2 == 1){
                result *= x;
            }
            x *= x;
            N /= 2;
        }

        return result;
    }
};
