class Solution {
public:
    bool isPalindrome(string s) {
        int len = s.length();
        int j = len - 1;
        int i = 0;
        while(i < j){
            if(isalnum(s[i]) && isalnum(s[j])){
                if(tolower((unsigned char)s[i]) == tolower((unsigned char)s[j])){
                    i++;
                    j--;
                }
                else return false;
            }
            else if(!isalnum(s[i])) i++;
            else j--;
        }
        return true;
    }
};
