// USING MAPS

class Solution {
public:
    bool isValid(string s) {
        if(s.length() < 2) return false;
        
        stack<char> st;
        unordered_map<char, char> mp = {
            {')', '('},
            {'}', '{'},
            {']', '['}
        };

        for(char c : s){
            if(mp.count(c) == 0){
                st.push(c);
            } else {
                if(st.empty() || st.top() != mp[c])
                    return false;
                st.pop();
            }
        }
        return st.empty();
    }
};
