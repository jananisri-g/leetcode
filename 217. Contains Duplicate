// TC: O(n) SC: O(n)
class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        unordered_set<int> unique;
        for(int i = 0; i < nums.size(); i++){
            if(unique.find(nums[i]) != unique.end()) return true;
            else unique.insert(nums[i]);
        }
        return false;
    }
};

