// TC: O(n) SC: O(n)

class Solution {
public:
    bool containsNearbyDuplicate(vector<int>& nums, int k) {
        unordered_map<int, int> lookup;
        bool result;
        for(int i = 0; i < nums.size(); i++){
            if(lookup.find(nums[i]) != lookup.end()){
                if(abs(i - lookup[nums[i]]) <= k) return true;
            }
            lookup[nums[i]] = i;
        }
        return false;
    }
};


