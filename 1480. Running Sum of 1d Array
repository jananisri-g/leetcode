// TC: O(N)
// SC: (N)

class Solution {
public:
    vector<int> runningSum(vector<int>& nums) {
        if(nums.size() < 2) return nums;
        vector<int> answer(nums.size());
        answer[0] = nums[0];
        for(int i = 1; i < nums.size(); i++)
            answer[i] = answer[i-1] + nums[i];
        return answer;
    }
};


